---
import type { CityData } from '../../data/types';

interface Props {
  tripId: string;
  cities: CityData[];
}
const { tripId, cities } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<section class="section">
  <div class="container">
    <div class="section-label">Itinerary</div>
    <h2 class="section-title">The journey</h2>
    <div class="cities-grid">
      {cities.map((c, i) => (
        <a class="city-card" href={`${base}${tripId}/${c.slug}/`} style={`--accent: ${c.accentColor}`}>
          <div class="city-card-num">{String(i + 1).padStart(2, '0')}</div>
          <h3 class="city-card-name">{c.name}</h3>
          <p class="city-card-dates">{c.dates} · {c.nights} {c.nights === 1 ? 'night' : 'nights'}</p>
          <p class="city-card-tagline">{c.tagline}</p>
          <span class="city-card-cta">Explore {c.name} →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 4rem 2rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pt-green); margin-bottom: 0.75rem; }
  .section-title { font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 300; margin-bottom: 2rem; }

  .cities-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
  .city-card {
    position: relative;
    display: block;
    padding: 1.75rem 1.5rem;
    background: white;
    border: 1px solid var(--cream-dark);
    border-top: 4px solid var(--accent);
    border-radius: var(--radius-lg);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .city-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
  .city-card-num { font-family: var(--font-display); font-size: 2.2rem; color: var(--accent); font-weight: 300; opacity: 0.4; line-height: 1; }
  .city-card-name { font-family: var(--font-display); font-size: 1.8rem; font-weight: 400; color: var(--ink); margin: 0.4rem 0 0.3rem; }
  .city-card-dates { font-size: 0.8rem; color: var(--accent); letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.8rem; }
  .city-card-tagline { font-size: 0.92rem; color: var(--ink-muted); line-height: 1.5; margin-bottom: 1rem; }
  .city-card-cta { font-size: 0.82rem; color: var(--ink); letter-spacing: 0.05em; }

  @media (max-width: 600px) { .section { padding: 2.5rem 1.25rem; } }
</style>