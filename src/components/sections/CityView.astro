---
import HotelCard from '../HotelCard.astro';
import RestaurantCard from '../RestaurantCard.astro';
import DayCard from '../DayCard.astro';
import MapSection from '../MapSection.astro';
import VenueBlock from './VenueBlock.astro';
import IceCreamSpots from './IceCreamSpots.astro';
import type { CityData, EffectiveTripStatus } from '../../data/types';

interface Props {
  city: CityData;
  showHero?: boolean;
  effectiveStatus?: EffectiveTripStatus;
}
const { city, showHero = true, effectiveStatus = 'planning' } = Astro.props;

// Visibility rules for hotels and restaurants:
//   1. Once the trip is completed or cancelled, hide everything — the event is
//      over; no point advertising anymore.
//   2. During planning/confirmed on a public build (PUBLIC_BUILD=true), only
//      show places tagged inEventBlock (official conference block / listing).
//      Personal picks stay private.
//   3. During planning/confirmed on a local build, show everything (personal
//      planning view — full shortlist visible to the author).
const isPublicBuild = import.meta.env.PUBLIC_BUILD === 'true';
const tripActive = effectiveStatus === 'planning' || effectiveStatus === 'confirmed';

const visibleHotels = tripActive
  ? (isPublicBuild ? city.hotels.filter(h => h.inEventBlock) : city.hotels)
  : [];
const visibleRestaurants = tripActive
  ? (isPublicBuild ? city.restaurants.filter(r => r.inEventBlock) : city.restaurants)
  : [];

const visibleHotelNames = new Set(visibleHotels.map(h => h.name));
const visibleRestaurantNames = new Set(visibleRestaurants.map(r => r.name));
const mapPointsForRender = city.mapPoints.filter(p => {
  if (p.type === 'hotel') return visibleHotelNames.has(p.name);
  if (p.type === 'restaurant') return visibleRestaurantNames.has(p.name);
  return true; // attractions, ice-cream stay
});

const showHotels = visibleHotels.length > 0;
const showRestaurants = visibleRestaurants.length > 0;

let altIdx = 0;
const nextAltClass = () => (altIdx++ % 2 === 0 ? 'section' : 'section section-alt');
---
{showHero && (
  <header class="city-hero" style={`--city-accent: ${city.accentColor}`}>
    <div class="city-hero-inner">
      <p class="city-eyebrow">{city.dates} · {city.nights} {city.nights === 1 ? 'night' : 'nights'}</p>
      <h1 class="city-title">{city.name}</h1>
      <p class="city-tagline">{city.tagline}</p>
    </div>
    <div class="city-hero-accent-bar" style={`background: ${city.accentColor}`}></div>
  </header>
)}

<section class={nextAltClass()}>
  <div class="container">
    <div class="section-label">Overview</div>
    <h2 class="section-title">{city.name} at a glance</h2>
    <p class="section-intro">Attractions, hotels and restaurants — all on one map.</p>
    <MapSection mapCenter={city.mapCenter} mapZoom={city.mapZoom} mapPoints={mapPointsForRender} accentColor={city.accentColor} />
  </div>
</section>

{city.venue && (
  <section class={nextAltClass()} id="event-venue">
    <div class="container">
      <div class="section-label">Event Venue</div>
      <h2 class="section-title">{city.venue.eventName}</h2>
      <p class="section-intro">Where the event happens — logistics, address, and access details all in one place.</p>
      <VenueBlock venue={city.venue} accentColor={city.accentColor} />
    </div>
  </section>
)}

{city.days.length > 0 && (
  <section class={nextAltClass()}>
    <div class="container">
      <div class="section-label">Day by Day</div>
      <h2 class="section-title">The itinerary</h2>
      <div class="days-grid">
        {city.days.map(d => <DayCard day={d} accentColor={city.accentColor} />)}
      </div>
      {city.transport && (
        <div class="transport-bar" style={`border-left-color: ${city.accentColor}; background: ${city.accentColor}0D`}>
          <span class="transport-icon">🚆</span>
          <p class="transport-text">{city.transport}</p>
        </div>
      )}
    </div>
  </section>
)}

{city.iceCreamSpots && city.iceCreamSpots.length > 0 && (
  <IceCreamSpots spots={city.iceCreamSpots} accentColor={city.accentColor} />
)}

{showHotels && (
  <section class={nextAltClass()}>
    <div class="container">
      <div class="section-label">Where to Stay</div>
      <h2 class="section-title">Hotels in {city.name}</h2>
      <div class="cards-grid">
        {visibleHotels.map(h => <HotelCard hotel={h} />)}
      </div>
    </div>
  </section>
)}

{showRestaurants && (
  <section class={nextAltClass()}>
    <div class="container">
      <div class="section-label">Where to Eat</div>
      <h2 class="section-title">Restaurants in {city.name}</h2>
      <div class="cards-grid">
        {visibleRestaurants.map(r => <RestaurantCard restaurant={r} />)}
      </div>
    </div>
  </section>
)}

<style>
  .city-hero {
    padding: 5rem 2rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--cream-dark);
    position: relative;
    background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(0,0,0,0.03), transparent);
  }
  .city-hero-inner { max-width: 700px; margin: 0 auto; }
  .city-eyebrow {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--city-accent);
    margin-bottom: 1rem;
  }
  .city-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 300;
    color: var(--ink);
    line-height: 0.9;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .city-tagline { font-size: 1.05rem; color: var(--ink-muted); font-weight: 300; line-height: 1.6; }
  .city-hero-accent-bar {
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 40px; height: 3px; border-radius: 2px;
  }
  .section { padding: 4rem 2rem; }
  .section-alt { background: white; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pt-green); margin-bottom: 0.75rem; }
  .section-title { font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 300; color: var(--ink); margin-bottom: 1rem; }
  .section-intro { font-size: 1rem; color: var(--ink-muted); max-width: 600px; margin-bottom: 2.5rem; line-height: 1.75; }
  .days-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  .transport-bar { display: flex; align-items: flex-start; gap: 0.75rem; padding: 1rem 1.25rem; border-left: 3px solid; border-radius: 0 var(--radius) var(--radius) 0; }
  .transport-icon { font-size: 1.1rem; flex-shrink: 0; }
  .transport-text { font-size: 0.875rem; color: var(--ink-muted); }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }

  @media (max-width: 600px) {
    .city-hero { padding: 4rem 1.5rem 3rem; }
    .section { padding: 2.5rem 1.25rem; }
    .days-grid, .cards-grid { grid-template-columns: 1fr; }
  }
</style>