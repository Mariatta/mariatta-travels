---
import type { TripConfig, EffectiveTripStatus } from '../../data/types';
import { getEffectiveStatus } from '../../data/trips';

interface Props {
  trip: TripConfig;
}
const { trip } = Astro.props;
const effStatus = getEffectiveStatus(trip);
const statusLabel: Record<EffectiveTripStatus, string> = {
  planning: 'Planning',
  confirmed: 'Confirmed',
  completed: 'Completed',
  cancelled: 'Cancelled',
};
---
<header class="hero" style={`--accent: ${trip.accentColor}`}>
  <div class="hero-inner">
    <span class={`status-badge status-badge-${effStatus}`}>{statusLabel[effStatus]}</span>
    <p class="hero-eyebrow">{trip.datesLabel}</p>
    <h1 class="hero-title">
      <span class="hero-emoji" aria-hidden="true">{trip.emoji}</span>
      {trip.title}
    </h1>
    <p class="hero-tagline">{trip.tagline}</p>
  </div>
  <div class="hero-accent-bar"></div>
</header>

<style>
  .hero {
    padding: 5rem 2rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--cream-dark);
    position: relative;
    background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(0,0,0,0.03), transparent);
  }
  .hero-inner { max-width: 760px; margin: 0 auto; }
  .status-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    border: 1px solid transparent;
    margin-bottom: 1rem;
  }
  .status-badge-planning {
    color: var(--gold);
    background: var(--gold-light);
    border-color: color-mix(in srgb, var(--gold) 25%, transparent);
  }
  .status-badge-confirmed {
    color: var(--pt-green);
    background: var(--green-light);
    border-color: color-mix(in srgb, var(--pt-green) 25%, transparent);
  }
  .status-badge-completed {
    color: var(--ink-muted);
    background: var(--cream-dark);
  }
  .status-badge-cancelled {
    color: var(--pt-red);
    background: var(--terra-light);
    border-color: color-mix(in srgb, var(--pt-red) 25%, transparent);
  }
  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 300;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }
  .hero-emoji { font-size: 0.9em; }
  .hero-tagline { font-size: 1.1rem; color: var(--ink-muted); line-height: 1.6; }
  .hero-accent-bar {
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 40px; height: 3px; border-radius: 2px; background: var(--accent);
  }
  @media (max-width: 600px) { .hero { padding: 4rem 1.5rem 3rem; } }
</style>