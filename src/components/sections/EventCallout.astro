---
import type { CityData } from '../../data/types';

interface Props {
  tripId: string;
  cities: CityData[];
  accentColor: string;
}
const { tripId, cities, accentColor } = Astro.props;
const base = import.meta.env.BASE_URL;

const eventsInTrip = cities
  .filter(c => c.venue)
  .map(c => ({ city: c, venue: c.venue! }));
---
{eventsInTrip.length > 0 && (
  <section class="section" style={`--accent: ${accentColor}`}>
    <div class="container">
      <div class="event-callouts">
        {eventsInTrip.map(({ city, venue }) => (
          <a class="event-callout" href={`${base}${tripId}/${city.slug}/#${'event-venue'}`}>
            <span class="event-icon" aria-hidden="true">🎤</span>
            <span class="event-meta">
              <span class="event-eyebrow">Event during this trip</span>
              <span class="event-name">{venue.eventName}</span>
              <span class="event-details">{city.name} · {venue.dates}</span>
            </span>
            <span class="event-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .section { padding: 0 2rem; margin-top: -1rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  .event-callouts { display: flex; flex-direction: column; gap: 0.75rem; }
  .event-callout {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--cream-dark);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius-lg);
    transition: transform 0.15s, border-color 0.15s;
  }
  .event-callout:hover { transform: translateY(-1px); border-color: var(--accent); }
  .event-icon { font-size: 1.4rem; flex-shrink: 0; }
  .event-meta { display: flex; flex-direction: column; gap: 0.1rem; flex: 1; min-width: 0; }
  .event-eyebrow { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); }
  .event-name { font-family: var(--font-display); font-size: 1.15rem; color: var(--ink); line-height: 1.2; }
  .event-details { font-size: 0.85rem; color: var(--ink-muted); }
  .event-arrow { font-size: 1.2rem; color: var(--accent); flex-shrink: 0; }

  @media (max-width: 600px) {
    .section { padding: 0 1.25rem; }
    .event-name { font-size: 1rem; }
  }
</style>