---
import type { CityData } from '../data/types';

interface Props {
  tripId: string;
  prev: CityData | null;
  next: CityData | null;
}
const { tripId, prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;
const tripHref = `${base}${tripId}/`;
---
<nav class="city-nav" aria-label="City navigation">
  <div class="city-nav-inner">
    {prev ? (
      <a class="city-nav-link prev" href={`${base}${tripId}/${prev.slug}/`}>
        <span class="arrow" aria-hidden="true">←</span>
        <span class="meta">
          <span class="label">Previous city</span>
          <span class="title">{prev.name}</span>
        </span>
      </a>
    ) : (
      <a class="city-nav-link prev city-nav-overview" href={tripHref}>
        <span class="arrow" aria-hidden="true">←</span>
        <span class="meta">
          <span class="label">Back to</span>
          <span class="title">Trip overview</span>
        </span>
      </a>
    )}
    {next ? (
      <a class="city-nav-link next" href={`${base}${tripId}/${next.slug}/`}>
        <span class="meta">
          <span class="label">Next city</span>
          <span class="title">{next.name}</span>
        </span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    ) : (
      <a class="city-nav-link next city-nav-overview" href={tripHref}>
        <span class="meta">
          <span class="label">Back to</span>
          <span class="title">Trip overview</span>
        </span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    )}
  </div>
</nav>

<style>
  .city-nav {
    border-top: 1px solid var(--cream-dark);
    padding: 1.5rem 2rem 0;
    max-width: 1100px;
    margin: 2rem auto 0;
  }
  .city-nav-inner {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: stretch;
  }
  .city-nav-link {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--cream-dark);
    border-radius: var(--radius-lg);
    background: white;
    transition: border-color 0.15s, transform 0.15s;
    flex: 1 1 40%;
    max-width: 340px;
  }
  .city-nav-link.next { justify-content: flex-end; text-align: right; margin-left: auto; }
  .city-nav-link:hover { border-color: var(--accent, var(--pt-green)); transform: translateY(-1px); }
  .city-nav-overview { background: var(--cream); }

  .meta { display: flex; flex-direction: column; gap: 0.1rem; }
  .label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-faint); }
  .title { font-family: var(--font-display); font-size: 1.1rem; color: var(--ink); }
  .arrow { font-size: 1.2rem; color: var(--ink-muted); }

  @media (max-width: 600px) {
    .city-nav { padding: 1rem 1rem 0; }
    .title { font-size: 1rem; }
  }
</style>