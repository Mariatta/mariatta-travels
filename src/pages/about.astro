---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { trips } from '../data/trips';
---
<Layout title="About" description="About Mariatta Travels — how this multi-trip planner was built with AI">
  <Nav current="about" />

  <header class="about-hero">
    <div class="about-hero-inner">
      <p class="about-eyebrow">Behind the Scenes</p>
      <h1 class="about-title">About This Site</h1>
      <p class="about-subtitle">
        A personal multi-trip planner, built entirely through conversation with AI.
      </p>
    </div>
  </header>

  <main>
    <section class="section">
      <div class="container">
        <div class="prose">
          <h2>What is this?</h2>
          <p>
            <strong>Mariatta Travels</strong> is a personal site that collects Mariatta's trip plans — family vacations and
            conference trips — each with its own itinerary, hotel and restaurant recommendations, interactive maps, budget,
            planning checklist, and expense log.
          </p>
          <p>
            It currently houses {trips.length} trip{trips.length === 1 ? '' : 's'}. Each lives at its own URL (e.g.
            <code>/portugal-2026/</code>) but shares the same layout, components, and data shapes. Adding a new trip is
            mostly a matter of dropping a new config and data files into <code>src/trips/&lt;slug&gt;/</code>.
          </p>
          <p>
            It is not a commercial travel guide or affiliate site.
          </p>

          <h2>100% generated by Claude</h2>
          <p>
            Every line of code, every data file, every component, and every piece of content on this site was generated
            by <a href="https://claude.ai/claude-code" target="_blank" rel="noopener">Claude Code</a> (Anthropic's AI coding
            assistant) through conversational prompting. No code was written by hand.
          </p>
          <p>
            The architecture — an <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> static site with a
            per-trip config, a shared <code>TripLayout</code>, pluggable sections for different trip types (family
            multi-city vs single-city conference), breadcrumbs, and prev/next trip navigation — was chosen and implemented
            entirely by Claude based on the requirements described in conversation.
          </p>

          <aside class="changelog-callout">
            <div class="changelog-callout-meta">
              <span class="changelog-callout-eyebrow">Prompt version history</span>
              <p class="changelog-callout-text">
                A numbered log of every prompt that built this site — from the first Portugal trip (v1.0) to the
                monorepo conversion (v2.0).
              </p>
            </div>
            <a class="changelog-callout-link" href={`${import.meta.env.BASE_URL}changelog/`}>Read the changelog →</a>
          </aside>

          <h2>From a single trip to a monorepo</h2>
          <p>
            This site started as <a href="https://mariatta.ca/portugal-trip/" target="_blank" rel="noopener">the Portugal trip
            planner</a> — a standalone repo for one family trip. As more trips came up (Taiwan, LinuxFest Northwest, the Python
            Core Dev Sprint), the "one repo per trip" pattern didn't scale. This monorepo was built through another conversation
            with Claude to share layout, components, and data schema across every trip, with a hub page indexing them all.
          </p>

          <h2>Trip statuses</h2>
          <p>
            Not every planned trip ends up happening. Each trip on the hub is tagged with one of:
          </p>
          <ul>
            <li><strong>Planning</strong> — still an idea, possibly not happening</li>
            <li><strong>Confirmed</strong> — booked, going ahead</li>
            <li><strong>Completed</strong> — trip happened (auto-derived from the end date)</li>
            <li><strong>Not taken</strong> — decided not to do it (budget, scheduling, life)</li>
          </ul>

          <h2>Blog posts about this project</h2>
          <p>
            Mariatta has written about the process of building these trip planners with AI:
          </p>
          <ul class="blog-posts">
            <li>
              <a href="https://mariatta.ca/posts/travel-planning-with-ai/" target="_blank" rel="noopener">
                Travel Planning with AI <span class="blog-part">— Part 1</span>
              </a>
            </li>
            <li>
              <a href="https://mariatta.ca/posts/travel-budgeting-without-spreadsheet/" target="_blank" rel="noopener">
                Travel Budgeting Without a Spreadsheet <span class="blog-part">— Part 2</span>
              </a>
            </li>
          </ul>

          <h2>Tools used</h2>
          <ul>
            <li><strong>Claude Code</strong> — AI coding assistant by Anthropic, used for all code generation, web research, and content writing</li>
            <li><strong>Astro</strong> — static site framework</li>
            <li><strong>Leaflet + OpenStreetMap</strong> — interactive maps</li>
            <li><strong>GitHub Pages</strong> — hosting</li>
          </ul>
        </div>
      </div>
    </section>
  </main>

  <Footer footerText="✈️ Mariatta Travels" repoUrl="https://github.com/Mariatta/mariatta-travels" />
</Layout>

<style>
  .about-hero {
    padding: 4rem 2rem 3rem;
    text-align: center;
    border-bottom: 1px solid var(--cream-dark);
  }
  .about-hero-inner { max-width: 600px; margin: 0 auto; }
  .about-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pt-green);
    margin-bottom: 0.75rem;
  }
  .about-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 300;
    line-height: 0.9;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .about-subtitle { font-size: 1.05rem; color: var(--ink-muted); line-height: 1.6; }

  .section { padding: 4rem 2rem; }
  .container { max-width: 750px; margin: 0 auto; }

  .prose h2 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .prose h2:first-child { margin-top: 0; }
  .prose p { font-size: 0.95rem; color: var(--ink-muted); line-height: 1.75; margin-bottom: 1rem; }
  .prose a { color: var(--pt-green); text-decoration: underline; text-underline-offset: 2px; }
  .prose a:hover { color: var(--ink); }
  .prose ul { list-style: disc; padding-left: 1.25rem; margin-bottom: 1rem; }
  .prose ul li { font-size: 0.95rem; color: var(--ink-muted); line-height: 1.75; margin-bottom: 0.4rem; }
  .prose code {
    font-size: 0.85em;
    background: var(--cream-dark);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: var(--ink);
  }
  .blog-part { color: var(--ink-faint); font-size: 0.9em; }

  .changelog-callout {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.1rem 1.25rem;
    margin: 1rem 0 0.5rem;
    background: white;
    border: 1px solid var(--cream-dark);
    border-left: 4px solid var(--pt-green);
    border-radius: var(--radius-lg);
    flex-wrap: wrap;
  }
  .changelog-callout-meta { flex: 1; min-width: 220px; display: flex; flex-direction: column; gap: 0.2rem; }
  .changelog-callout-eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pt-green);
    font-weight: 500;
  }
  .changelog-callout-text { font-size: 0.88rem; color: var(--ink-muted); line-height: 1.55; margin: 0; }
  .changelog-callout-link {
    color: var(--pt-green);
    font-size: 0.88rem;
    font-weight: 500;
    white-space: nowrap;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .changelog-callout-link:hover { color: var(--ink); }

  @media (max-width: 600px) {
    .about-hero { padding: 3rem 1.5rem 2rem; }
    .section { padding: 2.5rem 1.25rem; }
  }
</style>