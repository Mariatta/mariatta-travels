---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { trips, upcomingTrips, completedTrips, shelvedTrips, getEffectiveStatus } from '../data/trips';
import type { TripConfig, EffectiveTripStatus } from '../data/types';

const base = import.meta.env.BASE_URL;

const tripTypeLabel = (t: TripConfig) =>
  t.type === 'family' ? 'Family trip' : 'Conference';

const statusLabel: Record<EffectiveTripStatus, string> = {
  planning: 'Planning',
  confirmed: 'Confirmed',
  completed: 'Completed',
  cancelled: 'Not taken',
};

function cardProps(t: TripConfig) {
  const effStatus = getEffectiveStatus(t);
  return {
    trip: t,
    effStatus,
    classes: `trip-card status-${effStatus}`,
  };
}
---
<Layout title="Mariatta Travels" description="Trip planning & journals by Mariatta">
  <Nav current="home" />

  <header class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Travel & trip planning</p>
      <h1>Mariatta Travels</h1>
      <p class="tagline">Family vacations, conference trips, and the logistics behind them — planned out loud with AI.</p>
    </div>
  </header>

  <main>
    {upcomingTrips.length > 0 && (
      <section class="section">
        <div class="container">
          <h2 class="section-title">Upcoming</h2>
          <div class="trip-grid">
            {upcomingTrips.map(t => {
              const { effStatus, classes } = cardProps(t);
              return (
                <a class={classes} href={`${base}${t.id}/`} style={`--accent: ${t.accentColor}`}>
                  <div class="trip-card-emoji">{t.emoji}</div>
                  <div class="trip-card-meta">
                    <span class="trip-card-type">{tripTypeLabel(t)}</span>
                    <span class={`status-badge status-badge-${effStatus}`}>{statusLabel[effStatus]}</span>
                  </div>
                  <h3 class="trip-card-title">{t.title}</h3>
                  <p class="trip-card-dates">{t.datesLabel}</p>
                  <p class="trip-card-tagline">{t.tagline}</p>
                  <span class="trip-card-cta">Open trip →</span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {completedTrips.length > 0 && (
      <section class="section section-alt">
        <div class="container">
          <h2 class="section-title section-title-muted">Archive</h2>
          <div class="trip-grid">
            {completedTrips.map(t => {
              const { effStatus, classes } = cardProps(t);
              return (
                <a class={classes} href={`${base}${t.id}/`} style={`--accent: ${t.accentColor}`}>
                  <div class="trip-card-emoji">{t.emoji}</div>
                  <div class="trip-card-meta">
                    <span class="trip-card-type">{tripTypeLabel(t)}</span>
                    <span class={`status-badge status-badge-${effStatus}`}>{statusLabel[effStatus]}</span>
                  </div>
                  <h3 class="trip-card-title">{t.title}</h3>
                  <p class="trip-card-dates">{t.datesLabel}</p>
                  <p class="trip-card-tagline">{t.tagline}</p>
                  <span class="trip-card-cta">Revisit →</span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {shelvedTrips.length > 0 && (
      <section class="section">
        <div class="container">
          <h2 class="section-title section-title-muted">Shelved</h2>
          <p class="section-note">Trips that didn't end up happening.</p>
          <div class="trip-grid">
            {shelvedTrips.map(t => {
              const { effStatus, classes } = cardProps(t);
              return (
                <a class={classes} href={`${base}${t.id}/`} style={`--accent: ${t.accentColor}`}>
                  <div class="trip-card-emoji">{t.emoji}</div>
                  <div class="trip-card-meta">
                    <span class="trip-card-type">{tripTypeLabel(t)}</span>
                    <span class={`status-badge status-badge-${effStatus}`}>{statusLabel[effStatus]}</span>
                  </div>
                  <h3 class="trip-card-title">{t.title}</h3>
                  <p class="trip-card-dates">{t.datesLabel}</p>
                  <p class="trip-card-tagline">{t.tagline}</p>
                  <span class="trip-card-cta">View plan →</span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {trips.length === 0 && (
      <section class="section">
        <div class="container"><p>No trips yet.</p></div>
      </section>
    )}
  </main>

  <Footer
    footerText="✈️ Mariatta Travels"
    repoUrl="https://github.com/Mariatta/mariatta-travels"
  />
</Layout>

<style>
  .hero {
    padding: 6rem 2rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--cream-dark);
    background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(0,0,0,0.03), transparent);
  }
  .hero-inner { max-width: 720px; margin: 0 auto; }
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pt-green);
    margin-bottom: 1rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 6rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 1.2rem;
  }
  .tagline { font-size: 1.1rem; color: var(--ink-muted); line-height: 1.6; }

  .section { padding: 4rem 2rem; }
  .section-alt { background: white; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 400;
    margin-bottom: 2rem;
  }
  .section-title-muted { color: var(--ink-muted); }
  .section-note { color: var(--ink-faint); font-size: 0.9rem; margin-top: -1.5rem; margin-bottom: 1.75rem; }

  .trip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.25rem;
  }
  .trip-card {
    position: relative;
    display: block;
    padding: 1.75rem 1.5rem;
    background: white;
    border: 1px solid var(--cream-dark);
    border-top: 4px solid var(--accent);
    border-radius: var(--radius-lg);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .trip-card:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(0,0,0,0.08); }

  .status-completed { opacity: 0.78; }
  .status-completed:hover { opacity: 1; }
  .status-cancelled {
    opacity: 0.55;
    background: var(--cream);
    border-color: var(--cream-dark);
  }
  .status-cancelled:hover { transform: none; opacity: 0.75; box-shadow: none; }
  .status-cancelled .trip-card-title { text-decoration: line-through; text-decoration-color: var(--ink-faint); }

  .trip-card-emoji { font-size: 2rem; line-height: 1; }
  .trip-card-meta {
    margin-top: 0.7rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .trip-card-type {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .status-badge {
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.15rem 0.55rem;
    border-radius: 20px;
    border: 1px solid transparent;
  }
  .status-badge-planning {
    color: var(--gold);
    background: var(--gold-light);
    border-color: color-mix(in srgb, var(--gold) 25%, transparent);
  }
  .status-badge-confirmed {
    color: var(--pt-green);
    background: var(--green-light);
    border-color: color-mix(in srgb, var(--pt-green) 25%, transparent);
  }
  .status-badge-completed {
    color: var(--ink-muted);
    background: var(--cream-dark);
  }
  .status-badge-cancelled {
    color: var(--pt-red);
    background: var(--terra-light);
    border-color: color-mix(in srgb, var(--pt-red) 25%, transparent);
  }

  .trip-card-title { font-family: var(--font-display); font-size: 1.55rem; font-weight: 400; color: var(--ink); margin: 0.5rem 0 0.2rem; line-height: 1.15; }
  .trip-card-dates { font-size: 0.82rem; color: var(--ink-muted); margin-bottom: 0.75rem; }
  .trip-card-tagline { font-size: 0.92rem; color: var(--ink-muted); line-height: 1.5; margin-bottom: 1rem; }
  .trip-card-cta { font-size: 0.82rem; color: var(--ink); letter-spacing: 0.05em; }

  @media (max-width: 600px) {
    .hero { padding: 4rem 1.5rem 3rem; }
    .section { padding: 2.5rem 1.25rem; }
  }
</style>